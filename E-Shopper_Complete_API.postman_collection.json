{
  "info": {
    "_postman_id": "e-shopper-complete-api",
    "name": "E-Shopper Complete API Collection",
    "description": "Full API testing collection with JWT authentication, role-based authorization, and protected product/vendor management",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
