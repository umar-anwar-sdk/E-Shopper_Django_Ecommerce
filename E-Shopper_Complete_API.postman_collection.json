  "item": [
    {
      "name": "🔐 Authentication",
      "description": "User authentication, registration, and token management",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Response has tokens', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('tokens');",
                  "});",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.environment.set('customer_access_token', jsonData.tokens.access);",
                  "    pm.environment.set('customer_refresh_token', jsonData.tokens.refresh);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer_test@example.com\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Customer\",\n  \"phone_number\": \"9876543210\",\n  \"password\": \"TestPass123!@\",\n  \"confirm_password\": \"TestPass123!@\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["auth", "register", ""]
            }
          }
        },
